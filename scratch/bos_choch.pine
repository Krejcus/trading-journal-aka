// @version=6
indicator("Market Structure BoS/ChoCh (Nephew_Sam_ Clone)", shorttitle="BoS/ChoCh", overlay=true, max_lines_count=500, max_labels_count=500)

// ════════════════════════════════════════════════════════════════════════════
//                                  INPUTS
// ════════════════════════════════════════════════════════════════════════════

// Settings
pivot_lb = input.int(1, title="Pivot lb", minval=1, group="Settings")
pivot_rb = input.int(1, title="Pivot rb", minval=1, group="Settings")
breakout_type = input.string("Close", title="Breakout Confirmation", options=["Close", "Wick"], group="Settings")

// Show options
show_hh_ll = input.bool(false, title="Show HH/LL", group="Visuals")
show_hl_lh = input.bool(false, title="Show HL/LH", group="Visuals")
show_bos = input.bool(true, title="Show BOS", group="Visuals")
show_choch = input.bool(true, title="Show ChoCh", group="Visuals")

// Styling
color_bull = input.color(color.new(#2196F3, 0), title="Bullish Color", group="Styling")
color_bear = input.color(color.new(#FF9800, 0), title="Bearish Color", group="Styling")
line_width = input.int(1, title="Line Width", minval=1, maxval=4, group="Styling")

// ════════════════════════════════════════════════════════════════════════════
//                            STATE VARIABLES
// ════════════════════════════════════════════════════════════════════════════

var float last_ph = na
var int last_ph_bar = na
var float last_pl = na
var int last_pl_bar = na

var float prev_ph = na
var float prev_pl = na

// Trend: "Bullish", "Bearish", "None"
var string trend = "None"

// ════════════════════════════════════════════════════════════════════════════
//                            PIVOT DETECTION
// ════════════════════════════════════════════════════════════════════════════

ph = ta.pivothigh(high, pivot_lb, pivot_rb)
pl = ta.pivotlow(low, pivot_lb, pivot_rb)

// Handle Pivot Highs
if not na(ph)
    int p_bar = bar_index - pivot_rb
    string lbl_text = ""
    
    if not na(prev_ph)
        if ph > prev_ph
            if show_hh_ll
                lbl_text := "HH"
        else
            if show_hl_lh
                lbl_text := "LH"
    else
        if show_hh_ll
            lbl_text := "H"
            
    if lbl_text != ""
        label.new(p_bar, ph, lbl_text, 
                  style=label.style_label_down, 
                  color=color.new(color_bull, 100), 
                  textcolor=color_bull, 
                  size=size.small)
        
    prev_ph := ph
    last_ph := ph
    last_ph_bar := p_bar

// Handle Pivot Lows
if not na(pl)
    int p_bar = bar_index - pivot_rb
    string lbl_text = ""
    
    if not na(prev_pl)
        if pl < prev_pl
            if show_hh_ll
                lbl_text := "LL"
        else
            if show_hl_lh
                lbl_text := "HL"
    else
        if show_hh_ll
            lbl_text := "L"
            
    if lbl_text != ""
        label.new(p_bar, pl, lbl_text, 
                  style=label.style_label_up, 
                  color=color.new(color_bear, 100), 
                  textcolor=color_bear, 
                  size=size.small)
        
    prev_pl := pl
    last_pl := pl
    last_pl_bar := p_bar

// ════════════════════════════════════════════════════════════════════════════
//                            BREAKOUT DETECTION
// ════════════════════════════════════════════════════════════════════════════

float check_val_up = breakout_type == "Close" ? close : high
float check_val_down = breakout_type == "Close" ? close : low

bool break_up = not na(last_ph) and check_val_up > last_ph
bool break_down = not na(last_pl) and check_val_down < last_pl

// ════════════════════════════════════════════════════════════════════════════
//                            DRAWING FUNCTION
// ════════════════════════════════════════════════════════════════════════════

draw_structure_line(x1, y, x2, is_bos, is_bull) =>
    col = is_bull ? color_bull : color_bear
    style = is_bos ? line.style_dashed : line.style_solid
    
    // Draw horizontal breakout line
    line.new(x1, y, x2, y, color=col, width=line_width, style=style)
    
    // Draw label
    txt = is_bos ? "BOS" : "CHoCH"
    atr = ta.atr(14)
    offset = atr * 0.15
    
    label_style = is_bull ? label.style_label_down : label.style_label_up
    lbl_y = is_bull ? y + offset : y - offset
    
    label.new(math.round((x1 + x2) / 2), lbl_y, txt, 
              color=color.new(color.white, 100), 
              textcolor=col, 
              style=label_style, 
              size=size.small)

// ════════════════════════════════════════════════════════════════════════════
//                            TREND & STRUCTURE STATE
// ════════════════════════════════════════════════════════════════════════════

if break_up
    // Trend reversal = CHoCH, continuation = BOS
    is_bos = trend == "Bullish"
    is_show = is_bos ? show_bos : show_choch
    
    if is_show
        draw_structure_line(last_ph_bar, last_ph, bar_index, is_bos, true)
        
    trend := "Bullish"
    last_ph := na
    last_ph_bar := na

if break_down
    is_bos = trend == "Bearish"
    is_show = is_bos ? show_bos : show_choch
    
    if is_show
        draw_structure_line(last_pl_bar, last_pl, bar_index, is_bos, false)
        
    trend := "Bearish"
    last_pl := na
    last_pl_bar := na
